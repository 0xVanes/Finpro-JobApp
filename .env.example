# =========================================================================
# Contoh konfigurasi environment untuk data_ingestion.ipynb
# Salin file ini menjadi .env lalu isi nilainya. .env TIDAK di-commit.
#   cp .env.example .env
# =========================================================================

# --- OpenAI (embedding untuk Qdrant) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Qdrant Cloud (https://cloud.qdrant.io) ---
# Ambil URL & API key dari dashboard cluster Qdrant Cloud.
QDRANT_URL=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxx.europe-west3-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QDRANT_COLLECTION=jobs

# --- Aiven MySQL (https://aiven.io/free-mysql-database) ---
# Nilai host/port/user/password/db ada di halaman service Aiven.
# Aiven MySQL WAJIB SSL: unduh "CA certificate" (ca.pem) dari Aiven,
# simpan di ./secrets/aiven-ca.pem, lalu isi path-nya di MYSQL_SSL_CA.
MYSQL_HOST=your-service.aivencloud.com
MYSQL_PORT=12345
MYSQL_USER=avnadmin
MYSQL_PASSWORD=xxxxxxxxxxxxxxxxxxxx
MYSQL_DATABASE=defaultdb
MYSQL_SSL_CA=./secrets/aiven-ca.pem

# --- Ingestion (opsional) ---
# Ukuran batch embedding+upsert. Batch kecil = resume lebih sering tersimpan.
INGEST_BATCH_SIZE=32
